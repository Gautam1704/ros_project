<?xml version = "1.0"?>


<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
<gazebo>
  <plugin
    filename="libgz-sim-diff-drive-system.so"
    name="gz::sim::systems::DiffDrive">

        <!--Wheel information -->
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>

        <wheel_separation>0.35</wheel_separation>
        <wheel_radius>0.05</wheel_radius>

        <!-- limits -->
        <max_wheel_torque>200</max_wheel_torque>
        <max_wheel_acceleration>10.0</max_wheel_acceleration>

        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <tf_topic>/tf</tf_topic>
        <odom_topic>/odom</odom_topic>

        <!-- outputs-->
        <robot_base_frame>base_link</robot_base_frame>

        <!-- topics-->
        <topic>cmd_vel</topic> 
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>
  </plugin>
  <plugin
    filename="libgz-sim-joint-state-publisher-system.so"
    name="gz::sim::systems::JointStatePublisher">

    <topic>/joint_states</topic>

  </plugin>

</gazebo>
<gazebo reference="caster_wheel">
  <mu1 value="0.1"/>
  <mu2 value="0.1"/>
</gazebo>




<xacro:include filename="inertial_macros.xacro"/>

<!-- Base link -->
<link name = "base_link">

</link>

<joint name="base_footprint_joint" type="fixed">
  <parent link="base_link"/>
  <child link="base_footprint"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

<link name="base_footprint">
</link>

<!--Chassis-->
<joint name = "chassis_joint" type = "fixed">
    <parent link = "base_link"/>
    <child link= "chassis"/>
    <origin xyz = "-0.1 0 0" rpy = "0 0 0"/>
</joint>

<link name = "chassis">
    <visual>
        <origin xyz = "0.25 0 0.05" rpy = "0 0 0"/>
        <geometry>
            <box size = "0.5 0.3 0.1"/>
        </geometry>
        <material name = "blue">
            <color rgba = "0 0 1 1"/>
        </material>
    </visual>
    <collision>
        <origin xyz = "0.25 0 0.05" rpy = "0 0 0"/>
        <geometry>
            <box size = "0.5 0.3 0.1"/>
        </geometry>
    </collision>
    <xacro:inertial_box mass="0.5" x="0.5" y="0.3" z="0.1">
        <origin xyz = "0.25 0 0.05"/>
    </xacro:inertial_box>

</link>

<!-- Left wheel -->
<joint name = "left_wheel_joint" type = "continuous">
    <parent link = "base_link"/>
    <child link = "left_wheel"/>
    <origin xyz = "0 0.2 0" rpy = "0 0 0"/>
    <axis xyz = "0 1 0"/>
</joint>

<link name = "left_wheel">
    <visual>
        <origin xyz = "0 0 0" rpy = "-1.5708 0 0"/>
        <geometry>
            <cylinder radius = "0.05" length = "0.05"/>
        </geometry>
        <material name = "red">
            <color rgba = "1 0 0 1"/>
        </material>
    </visual>
    <collision>
        <origin xyz = "0 0 0" rpy = "-1.5708 0 0"/>
        <geometry>
            <cylinder radius = "0.05" length = "0.05"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass = "0.1" length= "0.05" radius="0.05">
        <origin xyz = "0 0 0" rpy = "-1.5708 0 0"/>
    </xacro:inertial_cylinder>
</link>


<!-- right wheel -->
<joint name = "right_wheel_joint" type = "continuous">
    <parent link = "base_link"/>
    <child link = "right_wheel"/>
    <origin xyz = "0 -0.2 0" rpy = "0 0 0"/>
    <axis xyz = "0 1 0"/>
</joint>

<link name = "right_wheel">
    <visual>
        <origin xyz = "0 0 0" rpy = "-1.5708 0 0"/>
        <geometry>
            <cylinder radius = "0.05" length = "0.05"/>
        </geometry>
        <material name = "red"/>
    </visual>
    <collision>
        <origin xyz = "0 0 0" rpy = "-1.5708 0 0"/>
        <geometry>
            <cylinder radius = "0.05" length = "0.05"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass = "0.1" length= "0.05" radius="0.05">
        <origin xyz = "0 0 0" rpy = "-1.5708 0 0"/>
    </xacro:inertial_cylinder>
</link>



<joint name  = "casterwheel" type = "fixed">
    <parent link = "chassis"/>
    <child link = "caster_wheel"/>
    <origin xyz = "0.1 0 0" rpy = "0 0 0"/>
</joint>

<link name = "caster_wheel">
    <visual>
        <origin xyz = "0.3 0 0"/>
        <geometry>
            <sphere radius = "0.05"/>
        </geometry>
        <material name = "red">
            <color rgba = "1 0 0 1"/>
        </material>
    </visual>
    <collision>
        <origin xyz = "0.3 0 0"/>
        <geometry>
            <sphere radius = "0.05"/>
        </geometry>
    </collision>
    <xacro:inertial_sphere mass = "0.04" radius="0.05">
        <origin xyz ="0.3 0 0"/>
    </xacro:inertial_sphere>
</link>





</robot>

